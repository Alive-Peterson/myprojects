      <aliases enabled='yes' />
      <column caption='Mortality Rate' datatype='real' name='[Calculation_0073682666283008]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([mortality_label]) / COUNT([patient_id])' />
      </column>
      <column caption='Mortality Status' datatype='string' name='[Calculation_0073682677518339]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [mortality_label]=1 THEN &quot;Died&quot;&#13;&#10;ELSE &quot;Survived&quot;&#13;&#10;END' />
      </column>
      <column caption='Ventilator Usage' datatype='real' name='[Calculation_0930202580398080]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([ventilation_required]) / COUNT([patient_id])' />
      </column>
      <column caption='Sepsis Rate' datatype='real' name='[Calculation_0930202580578305]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sepsis_flag]) / COUNT([patient_id])' />
      </column>
      <column caption='Ventilation' datatype='string' name='[Calculation_0930202584141826]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ventilation_required]=1&#13;&#10;THEN &quot;Ventilator&quot;&#13;&#10;ELSE &quot;No Ventilator&quot;&#13;&#10;END' />
